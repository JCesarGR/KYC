# ==============================================
# KYC PLATFORM - CONFIGURACIÓN
# ==============================================

# ────────────────────────────────────────────
# BASE DE DATOS
# ────────────────────────────────────────────
DATABASE_URL=postgresql://kyc_user:kyc_password@localhost:5432/kyc_db

# ────────────────────────────────────────────
# NEO4J GRAPH DATABASE (Opcional)
# ────────────────────────────────────────────
USE_NEO4J=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tu_password_neo4j

# ────────────────────────────────────────────
# APIS DE ENRIQUECIMIENTO
# ────────────────────────────────────────────

# HaveIBeenPwned - Brechas de datos
# Obtener en: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# Hunter.io - Verificación de email
# Obtener en: https://hunter.io/api
HUNTER_API_KEY=

# NumVerify - Validación de teléfono
# Obtener en: https://numverify.com
NUMVERIFY_API_KEY=

# APILayer - Alternativa a NumVerify
# Obtener en: https://apilayer.com
APILAYER_KEY=

# ────────────────────────────────────────────
# SANCIONES Y PEPS
# ────────────────────────────────────────────

# OpenSanctions - Base consolidada
# Obtener en: https://www.opensanctions.org
OPENSANCTIONS_API_KEY=

# ────────────────────────────────────────────
# CAPTCHA (Opcional para RND)
# ────────────────────────────────────────────

# 2captcha - Servicio de resolución de captcha
# Obtener en: https://2captcha.com
# Costo: ~$1 USD por 1000 captchas
TWOCAPTCHA_API_KEY=

# ────────────────────────────────────────────
# CONFIGURACIÓN GENERAL
# ────────────────────────────────────────────

# Umbral de coincidencia para fuzzy matching (0-100)
FUZZY_THRESHOLD=82

# Entorno: development, staging, production
ENVIRONMENT=development

# Nivel de logs: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Puerto de la API
PORT=8000

# ────────────────────────────────────────────
# SEGURIDAD
# ────────────────────────────────────────────

# Secret key para JWT (generar uno seguro en producción)
# Ejemplo: openssl rand -hex 32
JWT_SECRET_KEY=change_this_to_a_random_secret_key_in_production

# API Key para autenticación de clientes
API_KEY=change_this_in_production

# Algoritmo de encriptación JWT
JWT_ALGORITHM=HS256

# Tiempo de expiración de tokens (minutos)
JWT_EXPIRATION_MINUTES=30

# ────────────────────────────────────────────
# REDIS (Cache)
# ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ────────────────────────────────────────────
# EMAIL (Notificaciones)
# ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_password_de_app
SMTP_FROM=noreply@kycplatform.mx

# ────────────────────────────────────────────
# FRONTEND
# ────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000/api/v1

# ────────────────────────────────────────────
# RATE LIMITING
# ────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ────────────────────────────────────────────
# WEBHOOKS (Opcional)
# ────────────────────────────────────────────
WEBHOOK_SECRET=tu_secret_para_webhooks
WEBHOOK_ENABLED=false

# ────────────────────────────────────────────
# MONITOREO
# ────────────────────────────────────────────
SENTRY_DSN=
ENABLE_METRICS=true

# ────────────────────────────────────────────
# CUMPLIMIENTO
# ────────────────────────────────────────────
# Tiempo de retención de datos (días)
DATA_RETENTION_DAYS=365

# Habilitar auditoría extendida
EXTENDED_AUDIT=true
